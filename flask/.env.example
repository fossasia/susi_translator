FLASK_HOST=0.0.0.0
FLASK_PORT=5040
FLASK_DEBUG=false

CORS_ALLOWED_ORIGINS=http://localhost:5040,http://127.0.0.1:5040,https://localhost:5040,https://127.0.0.1:5040,https://172.22.171.58:5040

SESSION_TTL_SECONDS=7200
TRANSCRIBE_AUTOSTART_WORKER=true

# DATABASE_URL=sqlite:///susi.db

# Hugging Face Token (Optional)
# Used to bypass anonymous rate limits when downloading the 250MB+ Supertonic TTS ONNX models.
# HF_TOKEN="your_huggingface_token_here"

# Rate-limiting storage
# REDIS_URL=redis://localhost:6379/0

# Database
# SQLite (default, dev only). Run migrations before first start:
# cd flask && uv run python -m flask --app transcribe_server.py db upgrade
DATABASE_URL=sqlite:///susi.db

# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql://user:password@localhost:5432/susi

# JWT/Auth
# Required: minimum 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET_KEY=REPLACE_WITH_OUTPUT_OF_openssl_rand_-hex_32

JWT_COOKIE_SAMESITE=Lax

# Set to true when serving over HTTPS (use a reverse proxy like Nginx in prod).
JWT_COOKIE_SECURE=false
# JWT_COOKIE_SECURE=true

# CSRF protection for cookie-based JWT. Automatically enabled when
# JWT_COOKIE_SECURE=true. When enabled, every POST/PUT/DELETE request from the
# frontend must include an X-CSRF-TOKEN header (the frontend already does this).
# Override explicitly if needed:
# JWT_COOKIE_CSRF_PROTECT=true